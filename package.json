{
	"name": "noteguard",
	"version": "3.0.0",
	"description": "Lock notes and folders with a password. Session-only protection or real AES-GCM encryption per path.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run",
		"test:watch": "vitest",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"encryption",
		"password",
		"aes-gcm",
		"privacy"
	],
	"author": "SirStig",
	"license": "MIT",
	"devDependencies": {
		"@types/mustache": "^4.2.6",
		"@types/node": "^22.0.0",
		"@typescript-eslint/eslint-plugin": "^8.0.0",
		"@typescript-eslint/parser": "^8.0.0",
		"builtin-modules": "^4.0.0",
		"esbuild": "^0.25.0",
		"obsidian": "latest",
		"tslib": "^2.7.0",
		"typescript": "^5.5.0",
		"vitest": "^2.1.9"
	},
	"dependencies": {
		"mustache": "^4.2.0"
	}
}
